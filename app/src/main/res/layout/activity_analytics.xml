<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:padding="20dp"
    android:background="@drawable/login_bg">

    <LinearLayout
        android:orientation="vertical"
        android:layout_width="match_parent"
        android:layout_height="wrap_content">

        <!-- PAGE TITLE -->
        <TextView
            android:id="@+id/tvAnalyticsTitle"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Study Analytics"
            android:textSize="24sp"
            android:textStyle="bold"
            android:textColor="#4F6F64"
            android:letterSpacing="0.03"
            android:layout_gravity="center_horizontal"
            android:paddingBottom="20dp"
            android:layout_marginTop="20dp" />

        <!-- ANALYTICS CARDS ROW -->
        <LinearLayout
            android:orientation="horizontal"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:weightSum="3"
            android:gravity="center"
            android:layout_marginTop="15dp">

            <!-- TOTAL SESSIONS -->
            <androidx.cardview.widget.CardView
                android:id="@+id/cardTotalSessions"
                android:layout_width="0dp"
                android:layout_weight="1"
                android:layout_height="110dp"
                android:layout_margin="8dp"
                android:clipToOutline="true"
                app:cardCornerRadius="18dp"
                app:cardElevation="6dp"
                android:backgroundTint="#C48CF7">

                <TextView
                    android:id="@+id/tvTotalSessions"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:text="Total Sessions\n0"
                    android:textColor="#FFFFFF"
                    android:textSize="17sp"
                    android:gravity="center"
                    android:textStyle="bold"
                    android:padding="8dp" />
            </androidx.cardview.widget.CardView>

            <!-- AVG STUDY -->
            <androidx.cardview.widget.CardView
                android:id="@+id/cardAvgStudy"
                android:layout_width="0dp"
                android:layout_weight="1"
                android:layout_height="110dp"
                android:layout_margin="8dp"
                android:clipToOutline="true"
                app:cardCornerRadius="18dp"
                app:cardElevation="6dp"
                android:backgroundTint="#7EC8FF">

                <TextView
                    android:id="@+id/tvAvgStudy"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:text="Avg Study\n0 hr"
                    android:textColor="#FFFFFF"
                    android:textSize="17sp"
                    android:gravity="center"
                    android:textStyle="bold"
                    android:padding="8dp" />
            </androidx.cardview.widget.CardView>

            <!-- TOP SUBJECT -->
            <androidx.cardview.widget.CardView
                android:id="@+id/cardTopSubject"
                android:layout_width="0dp"
                android:layout_weight="1"
                android:layout_height="110dp"
                android:layout_margin="8dp"
                android:clipToOutline="true"
                app:cardCornerRadius="18dp"
                app:cardElevation="6dp"
                android:backgroundTint="#8DE6A1">

                <TextView
                    android:id="@+id/tvTopSubject"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:text="Top Subject\n—"
                    android:textColor="#FFFFFF"
                    android:textSize="17sp"
                    android:gravity="center"
                    android:textStyle="bold"
                    android:padding="8dp" />
            </androidx.cardview.widget.CardView>
        </LinearLayout>

        <!-- ✅ NEW STATS ROW 2 -->
        <LinearLayout
            android:orientation="horizontal"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:weightSum="3"
            android:gravity="center"
            android:layout_marginTop="15dp">

            <!-- TOTAL RECORDINGS -->
            <androidx.cardview.widget.CardView
                android:id="@+id/cardTotalRecordings"
                android:layout_width="0dp"
                android:layout_weight="1"
                android:layout_height="110dp"
                android:layout_margin="8dp"
                android:clipToOutline="true"
                app:cardCornerRadius="18dp"
                app:cardElevation="6dp"
                android:backgroundTint="#FF9E67">

                <TextView
                    android:id="@+id/tvTotalRecordings"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:text="Total Recordings\n0"
                    android:textColor="#FFFFFF"
                    android:textSize="17sp"
                    android:gravity="center"
                    android:textStyle="bold"
                    android:padding="8dp" />
            </androidx.cardview.widget.CardView>

            <!-- AVG QUIZ SCORE -->
            <androidx.cardview.widget.CardView
                android:id="@+id/cardAverageQuizScore"
                android:layout_width="0dp"
                android:layout_weight="1"
                android:layout_height="110dp"
                android:layout_margin="8dp"
                android:clipToOutline="true"
                app:cardCornerRadius="18dp"
                app:cardElevation="6dp"
                android:backgroundTint="#F26B7B">

                <TextView
                    android:id="@+id/tvAverageQuizScore"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:text="Avg Quiz Score\n0%"
                    android:textColor="#FFFFFF"
                    android:textSize="17sp"
                    android:gravity="center"
                    android:textStyle="bold"
                    android:padding="8dp" />
            </androidx.cardview.widget.CardView>

            <!-- TOTAL QUIZZES -->
            <androidx.cardview.widget.CardView
                android:id="@+id/cardTotalQuizzes"
                android:layout_width="0dp"
                android:layout_weight="1"
                android:layout_height="110dp"
                android:layout_margin="8dp"
                android:clipToOutline="true"
                app:cardCornerRadius="18dp"
                app:cardElevation="6dp"
                android:backgroundTint="#9F8FF1">

                <TextView
                    android:id="@+id/tvTotalQuizzes"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:text="Total Quizzes\n0"
                    android:textColor="#FFFFFF"
                    android:textSize="17sp"
                    android:gravity="center"
                    android:textStyle="bold"
                    android:padding="8dp" />
            </androidx.cardview.widget.CardView>
        </LinearLayout>

        <!-- SECTION HEADER -->
        <TextView
            android:id="@+id/tvAnalyticsGraphLabel"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Study Progress Chart"
            android:textSize="18sp"
            android:textStyle="bold"
            android:textColor="#333333"
            android:layout_marginTop="35dp"
            android:layout_marginBottom="15dp" />

        <!-- LINE CHART -->
        <com.github.mikephil.charting.charts.LineChart
            android:id="@+id/lineChart"
            android:layout_width="match_parent"
            android:layout_height="270dp"
            android:layout_marginBottom="30dp"
            android:background="@android:color/white"
            android:elevation="6dp"
            android:padding="12dp" />

    </LinearLayout>
</ScrollView>
