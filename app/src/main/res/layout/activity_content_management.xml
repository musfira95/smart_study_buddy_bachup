<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@drawable/login_bg">

    <!-- GREEN HEADER (like Your Recordings) -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="68dp"
        android:orientation="horizontal"
        android:gravity="bottom|center_horizontal"
        android:background="#4F6F64"
        android:paddingHorizontal="12dp"
        android:paddingBottom="10dp">

        <ImageView
            android:id="@+id/btnBack"
            android:layout_width="36dp"
            android:layout_height="36dp"
            android:src="@drawable/ic_back_arrow"
            android:padding="6dp"
            android:clickable="true"
            android:focusable="true"/>

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="Manage Content"
            android:textSize="20sp"
            android:textStyle="bold"
            android:textColor="#FFFFFF"
            android:gravity="center"/>

        <View
            android:layout_width="36dp"
            android:layout_height="36dp"/>
    </LinearLayout>

    <!-- SCROLL CONTENT -->
    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:fillViewport="true">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:gravity="center_horizontal"
            android:paddingHorizontal="16dp"
            android:paddingTop="20dp"
            android:paddingBottom="20dp">

            <!-- ICON + TITLE -->
            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:gravity="center"
                android:layout_marginBottom="20dp">

                <ImageView
                    android:layout_width="60dp"
                    android:layout_height="60dp"
                    android:src="@drawable/ic_content"
                    android:padding="14dp"
                    android:background="@drawable/circle_green"
                    android:layout_gravity="center"
                    android:layout_marginBottom="10dp"/>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="App Information"
                    android:textSize="17sp"
                    android:textStyle="bold"
                    android:textColor="#2C2C2C"
                    android:gravity="center"
                    android:layout_marginBottom="4dp"/>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Update the app details shown to users"
                    android:textSize="12sp"
                    android:textColor="#888888"
                    android:gravity="center"/>
            </LinearLayout>

            <!-- MAIN CARD -->
            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:cardCornerRadius="18dp"
                app:cardElevation="6dp"
                app:cardBackgroundColor="#FFFFFF">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="20dp">

                    <!-- APP VERSION -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical"
                        android:layout_marginBottom="8dp">
                        <TextView
                            android:layout_width="22dp"
                            android:layout_height="22dp"
                            android:text="&#128241;"
                            android:textSize="14sp"
                            android:gravity="center"/>
                        <TextView
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="App Version"
                            android:textSize="13sp"
                            android:textStyle="bold"
                            android:textColor="#4F6F64"
                            android:layout_marginStart="8dp"/>
                    </LinearLayout>
                    <EditText
                        android:id="@+id/etAppVersion"
                        android:layout_width="match_parent"
                        android:layout_height="50dp"
                        android:hint="e.g., 1.0.0"
                        android:inputType="text"
                        android:paddingHorizontal="14dp"
                        android:textSize="14sp"
                        android:textColor="#222222"
                        android:textColorHint="#BBBBBB"
                        android:background="@drawable/edittext_bg_rounded"
                        android:layout_marginBottom="18dp"/>

                    <View android:layout_width="match_parent" android:layout_height="1dp"
                        android:background="#F0F0F0" android:layout_marginBottom="18dp"/>

                    <!-- APP DESCRIPTION -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical"
                        android:layout_marginBottom="8dp">
                        <TextView
                            android:layout_width="22dp"
                            android:layout_height="22dp"
                            android:text="&#128221;"
                            android:textSize="14sp"
                            android:gravity="center"/>
                        <TextView
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="App Description"
                            android:textSize="13sp"
                            android:textStyle="bold"
                            android:textColor="#4F6F64"
                            android:layout_marginStart="8dp"/>
                    </LinearLayout>
                    <EditText
                        android:id="@+id/etAppDescription"
                        android:layout_width="match_parent"
                        android:layout_height="110dp"
                        android:hint="Enter app description"
                        android:inputType="textMultiLine"
                        android:paddingHorizontal="14dp"
                        android:paddingVertical="12dp"
                        android:textSize="14sp"
                        android:textColor="#222222"
                        android:textColorHint="#BBBBBB"
                        android:background="@drawable/edittext_bg_rounded"
                        android:gravity="top|start"
                        android:layout_marginBottom="18dp"/>

                    <View android:layout_width="match_parent" android:layout_height="1dp"
                        android:background="#F0F0F0" android:layout_marginBottom="18dp"/>

                    <!-- SUPPORT EMAIL -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical"
                        android:layout_marginBottom="8dp">
                        <ImageView
                            android:layout_width="22dp"
                            android:layout_height="22dp"
                            android:src="@drawable/ic_email"
                            android:padding="2dp"/>
                        <TextView
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="Support Email"
                            android:textSize="13sp"
                            android:textStyle="bold"
                            android:textColor="#4F6F64"
                            android:layout_marginStart="8dp"/>
                    </LinearLayout>
                    <EditText
                        android:id="@+id/etSupportEmail"
                        android:layout_width="match_parent"
                        android:layout_height="50dp"
                        android:hint="support@example.com"
                        android:inputType="textEmailAddress"
                        android:paddingHorizontal="14dp"
                        android:textSize="14sp"
                        android:textColor="#222222"
                        android:textColorHint="#BBBBBB"
                        android:background="@drawable/edittext_bg_rounded"
                        android:layout_marginBottom="18dp"/>

                    <View android:layout_width="match_parent" android:layout_height="1dp"
                        android:background="#F0F0F0" android:layout_marginBottom="18dp"/>

                    <!-- SUPPORT PHONE -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical"
                        android:layout_marginBottom="8dp">
                        <TextView
                            android:layout_width="22dp"
                            android:layout_height="22dp"
                            android:text="&#128222;"
                            android:textSize="14sp"
                            android:gravity="center"/>
                        <TextView
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="Support Phone"
                            android:textSize="13sp"
                            android:textStyle="bold"
                            android:textColor="#4F6F64"
                            android:layout_marginStart="8dp"/>
                    </LinearLayout>
                    <EditText
                        android:id="@+id/etSupportPhone"
                        android:layout_width="match_parent"
                        android:layout_height="50dp"
                        android:hint="+1-555-1234"
                        android:inputType="phone"
                        android:paddingHorizontal="14dp"
                        android:textSize="14sp"
                        android:textColor="#222222"
                        android:textColorHint="#BBBBBB"
                        android:background="@drawable/edittext_bg_rounded"/>

                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <!-- SAVE BUTTON -->
            <Button
                android:id="@+id/btnSaveContent"
                android:layout_width="match_parent"
                android:layout_height="52dp"
                android:text="Save Changes"
                android:textSize="16sp"
                android:textStyle="bold"
                android:textColor="#FFFFFF"
                android:background="@drawable/button_rounded"
                android:layout_marginTop="20dp"/>

        </LinearLayout>
    </ScrollView>

</LinearLayout>
