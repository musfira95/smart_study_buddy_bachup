<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:padding="20dp"
    android:background="@drawable/login_bg">

    <LinearLayout
        android:orientation="vertical"
        android:layout_width="match_parent"
        android:layout_height="wrap_content">

        <!-- HEADING -->
        <TextView
            android:id="@+id/tvHelpTitle"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Help and Support"
            android:textSize="24sp"
            android:textStyle="bold"
            android:textColor="#4F6F64"
            android:layout_marginBottom="20dp"
            android:letterSpacing="0.02"/>

        <!-- CARD CONTAINER -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="@android:color/white"
            android:elevation="6dp"
            android:padding="18dp"
            android:layout_marginTop="10dp"
            android:layout_marginBottom="20dp">

            <TextView
                android:id="@+id/tvHelpDescription"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="If you need assistance, feel free to contact our support team.\nWe are here to help you with any issues or questions."
                android:textSize="16sp"
                android:textColor="#333333"
                android:lineSpacingExtra="5dp"/>

            <View
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:background="#E0E0E0"
                android:layout_marginVertical="16dp"/>

            <!-- CONTACT EMAIL -->
            <TextView
                android:id="@+id/tvHelpEmail"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="📧 Email: support@smartstudybuddy.com"
                android:textSize="15sp"
                android:textStyle="bold"
                android:textColor="#4F6F64"
                android:layout_marginTop="8dp"/>

            <!-- CONTACT PHONE -->
            <TextView
                android:id="@+id/tvHelpPhone"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="📞 Phone: +1 234 567 890"
                android:textSize="15sp"
                android:textStyle="bold"
                android:textColor="#4F6F64"
                android:layout_marginTop="10dp"/>

        </LinearLayout>

    </LinearLayout>
</ScrollView>
