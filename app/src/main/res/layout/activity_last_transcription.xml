<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:fillViewport="true"
    android:background="@drawable/login_bg">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center"
        android:orientation="vertical"
        android:padding="24dp">

        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="40dp"
            android:layout_marginBottom="40dp"
            app:cardCornerRadius="20dp"
            app:cardElevation="6dp"
            app:cardBackgroundColor="@android:color/white"
            app:useCompatPadding="true">


        <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="24dp"
                android:gravity="center_horizontal">

                <!-- TITLE -->
                <TextView
                    android:id="@+id/tvScreenHeading"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Last Transcription"
                    android:textSize="22sp"
                    android:textStyle="bold"
                    android:textColor="#4F6F64"
                    android:layout_marginBottom="20dp"/>

                <!-- TITLE INPUT -->
                <EditText
                    android:id="@+id/etLastTitle"
                    android:layout_width="match_parent"
                    android:layout_height="48dp"
                    android:background="@drawable/edittext_bg_rounded"
                    android:hint="Title"
                    android:padding="12dp"
                    android:textSize="16sp"
                    android:textColor="#000000"
                    android:textColorHint="#777777"/>

                <!-- DATE TIME -->
                <TextView
                    android:id="@+id/tvLastTime"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Date  Time"
                    android:textSize="13sp"
                    android:textColor="#777777"
                    android:gravity="end"
                    android:layout_marginTop="6dp"
                    android:layout_marginBottom="14dp"/>

                <!-- TRANSCRIPTION CARD -->
                <androidx.cardview.widget.CardView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    app:cardCornerRadius="14dp"
                    app:cardElevation="4dp"
                    app:cardBackgroundColor="@android:color/white"
                    android:background="@android:color/white"
                    android:layout_marginBottom="24dp">

                    <TextView
                        android:id="@+id/tvLastText"
                        android:layout_width="match_parent"
                        android:layout_height="120dp"
                        android:text="Transcription content will appear here"
                        android:textSize="16sp"
                        android:textColor="#333333"
                        android:padding="14dp"/>
                </androidx.cardview.widget.CardView>

                <!-- VIEW ALL BUTTON -->
                <LinearLayout
                    android:id="@+id/btnAllTranscripts"
                    android:layout_width="match_parent"
                    android:layout_height="48dp"
                    android:gravity="center"
                    android:background="@drawable/button_rounded"
                    android:clickable="true"
                    android:focusable="true">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="View All Transcriptions"
                        android:textSize="16sp"
                        android:textStyle="bold"
                        android:textColor="@android:color/white"/>
                </LinearLayout>

            </LinearLayout>
        </androidx.cardview.widget.CardView>
        <!-- ================= BOTTOM NAV BAR (SAME AS UPLOAD AUDIO) ================= -->
        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="80dp"
            android:layout_marginTop="24dp"
            app:cardCornerRadius="22dp"
            app:cardElevation="6dp"
            android:background="@drawable/bottom_nav_bg">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:orientation="horizontal"
                android:gravity="center"
                android:weightSum="4">

                <!-- Home -->
                <ImageView
                    android:id="@+id/navHome"
                    android:layout_width="0dp"
                    android:layout_height="32dp"
                    android:layout_weight="1"
                    android:src="@drawable/ic_home"
                    app:tint="#4F6F64" />

                <!-- Analytics -->
                <ImageView
                    android:id="@+id/navAnalytics"
                    android:layout_width="0dp"
                    android:layout_height="32dp"
                    android:layout_weight="1"
                    android:src="@drawable/ic_analytics"
                    app:tint="#4CAF50" />

                <!-- Settings -->
                <ImageView
                    android:id="@+id/navSettings"
                    android:layout_width="0dp"
                    android:layout_height="32dp"
                    android:layout_weight="1"
                    android:src="@drawable/ic_settings"
                    app:tint="#3F90B5" />

                <!-- Profile -->
                <ImageView
                    android:id="@+id/navProfile"
                    android:layout_width="0dp"
                    android:layout_height="32dp"
                    android:layout_weight="1"
                    android:src="@drawable/ic_user"
                    app:tint="#4F6F64" />

            </LinearLayout>
        </androidx.cardview.widget.CardView>


    </LinearLayout>
</ScrollView>
