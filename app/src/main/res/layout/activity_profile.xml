<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/login_bg"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <!-- BACK ARROW -->
        <ImageView
            android:id="@+id/btnBackProfile"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:layout_marginTop="36dp"
            android:layout_marginStart="12dp"
            android:src="@drawable/ic_back_arrow"
            android:padding="6dp"
            android:tint="#4F6F64"
            android:clickable="true"
            android:focusable="true"
            android:background="?attr/selectableItemBackgroundBorderless"/>

        <!-- PROFILE PIC -->
        <FrameLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="10dp">

            <!-- Round profile image centered -->
            <FrameLayout
                android:layout_width="110dp"
                android:layout_height="110dp"
                android:layout_gravity="center_horizontal">

                <ImageView
                    android:id="@+id/ivProfilePic"
                    android:layout_width="110dp"
                    android:layout_height="110dp"
                    android:src="@drawable/ic_user_pro"
                    android:background="@drawable/circle_bgg"
                    android:padding="18dp"
                    android:scaleType="centerCrop"
                    android:clipToOutline="true"
                    android:clickable="true"
                    android:focusable="true"
                    android:elevation="4dp"/>

                <!-- Camera badge -->
                <LinearLayout
                    android:layout_width="28dp"
                    android:layout_height="28dp"
                    android:layout_gravity="bottom|end"
                    android:background="@drawable/button_rounded"
                    android:gravity="center"
                    android:elevation="6dp">
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="+"
                        android:textSize="14sp"
                        android:textColor="@android:color/white"
                        android:textStyle="bold"/>
                </LinearLayout>
            </FrameLayout>
        </FrameLayout>

        <!-- NAME + EMAIL centered -->
        <TextView
            android:id="@+id/tvName"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Full Name"
            android:textSize="22sp"
            android:textStyle="bold"
            android:textColor="#2B2B2B"
            android:layout_gravity="center_horizontal"
            android:layout_marginTop="10dp"/>

        <TextView
            android:id="@+id/tvEmail"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="email@email.com"
            android:textSize="13sp"
            android:textColor="#4F6F64"
            android:layout_gravity="center_horizontal"
            android:layout_marginTop="2dp"
            android:layout_marginBottom="16dp"/>

        <!-- hidden fields for Java compatibility -->
        <TextView android:id="@+id/tvPhone" android:layout_width="wrap_content" android:layout_height="0dp" android:visibility="gone"/>
        <TextView android:id="@+id/tvUniversity" android:layout_width="wrap_content" android:layout_height="0dp" android:visibility="gone"/>
        <TextView android:id="@+id/tvCourse" android:layout_width="wrap_content" android:layout_height="0dp" android:visibility="gone"/>

        <!-- EDIT PROFILE BUTTON (small, centered) -->
        <LinearLayout
            android:id="@+id/btnEditProfile"
            android:layout_width="wrap_content"
            android:layout_height="36dp"
            android:layout_gravity="center_horizontal"
            android:paddingStart="20dp"
            android:paddingEnd="20dp"
            android:gravity="center"
            android:background="@drawable/button_outline"
            android:orientation="horizontal"
            android:clickable="true"
            android:focusable="true"
            android:layout_marginBottom="20dp">
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Edit Profile"
                android:textSize="13sp"
                android:textStyle="bold"
                android:textColor="#4F6F64"/>
        </LinearLayout>

        <!-- STATS CARD -->
        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginStart="20dp"
            android:layout_marginEnd="20dp"
            android:layout_marginBottom="14dp"
            app:cardCornerRadius="16dp"
            app:cardElevation="4dp"
            app:cardBackgroundColor="@android:color/white">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="16dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="My Stats"
                    android:textColor="#4F6F64"
                    android:textSize="15sp"
                    android:textStyle="bold"
                    android:layout_marginBottom="14dp"/>

                <!-- 3 stat boxes -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:weightSum="3">

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical"
                        android:gravity="center"
                        android:background="#EDF6F2"
                        android:padding="12dp"
                        android:layout_marginEnd="5dp">
                        <TextView
                            android:id="@+id/tvStatRecordings"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="0"
                            android:textSize="26sp"
                            android:textStyle="bold"
                            android:textColor="#4F6F64"/>
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Recordings"
                            android:textSize="10sp"
                            android:textColor="#888888"/>
                    </LinearLayout>

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical"
                        android:gravity="center"
                        android:background="#EDF6F2"
                        android:padding="12dp"
                        android:layout_marginEnd="5dp">
                        <TextView
                            android:id="@+id/tvStatQuizzes"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="0"
                            android:textSize="26sp"
                            android:textStyle="bold"
                            android:textColor="#4F6F64"/>
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Quizzes"
                            android:textSize="10sp"
                            android:textColor="#888888"/>
                    </LinearLayout>

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical"
                        android:gravity="center"
                        android:background="#EDF6F2"
                        android:padding="12dp">
                        <TextView
                            android:id="@+id/tvStatFlashcards"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="0"
                            android:textSize="26sp"
                            android:textStyle="bold"
                            android:textColor="#4F6F64"/>
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Flashcards"
                            android:textSize="10sp"
                            android:textColor="#888888"/>
                    </LinearLayout>
                </LinearLayout>

                <View
                    android:layout_width="match_parent"
                    android:layout_height="1dp"
                    android:background="#EEEEEE"
                    android:layout_marginTop="12dp"
                    android:layout_marginBottom="10dp"/>

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical">
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Avg Quiz Score: "
                        android:textColor="#555555"
                        android:textSize="13sp"/>
                    <TextView
                        android:id="@+id/tvStatAvgScore"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="N/A"
                        android:textColor="#4F6F64"
                        android:textSize="14sp"
                        android:textStyle="bold"/>
                </LinearLayout>
            </LinearLayout>
        </androidx.cardview.widget.CardView>

        <!-- CHANGE PASSWORD BUTTON -->
        <LinearLayout
            android:id="@+id/btnChangePassword"
            android:layout_width="match_parent"
            android:layout_height="50dp"
            android:layout_marginStart="24dp"
            android:layout_marginEnd="24dp"
            android:layout_marginBottom="10dp"
            android:gravity="center"
            android:background="@drawable/button_outline"
            android:clickable="true"
            android:focusable="true">
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Change Password"
                android:textSize="15sp"
                android:textStyle="bold"
                android:textColor="#4F6F64"/>
        </LinearLayout>

        <!-- LOGOUT BUTTON -->
        <LinearLayout
            android:id="@+id/logoutBtn"
            android:layout_width="match_parent"
            android:layout_height="50dp"
            android:layout_marginStart="24dp"
            android:layout_marginEnd="24dp"
            android:layout_marginBottom="30dp"
            android:gravity="center"
            android:background="@drawable/button_rounded"
            android:clickable="true"
            android:focusable="true">
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Logout"
                android:textSize="15sp"
                android:textStyle="bold"
                android:textColor="@android:color/white"/>
        </LinearLayout>

    </LinearLayout>
</ScrollView>
