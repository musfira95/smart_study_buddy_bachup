<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/login_bg"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:gravity="center"
        android:orientation="vertical"
        android:padding="24dp">

        <!-- WHITE CARD (LOGIN STYLE) -->
        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="40dp"
            android:layout_marginBottom="40dp"
            app:cardCornerRadius="20dp"
            app:cardElevation="6dp"
            app:cardBackgroundColor="@android:color/white">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="24dp">

                <!-- TITLE -->
                <TextView
                    android:id="@+id/tvDetailsTitle"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Uploaded File Details"
                    android:textSize="22sp"
                    android:textStyle="bold"
                    android:textColor="#4F6F64"
                    android:layout_gravity="center_horizontal"
                    android:layout_marginBottom="20dp"/>

                <!-- FILE NAME -->
                <TextView
                    android:id="@+id/fileNameTv"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="File Name"
                    android:textColor="#4F6F64"
                    android:textSize="16sp"
                    android:textStyle="bold"/>

                <TextView
                    android:id="@+id/fileNameValue"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="recording_01.3gp"
                    android:textColor="#333333"
                    android:textSize="15sp"
                    android:layout_marginBottom="16dp"/>

                <!-- FILE SIZE -->
                <TextView
                    android:id="@+id/fileSizeTv"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="File Size"
                    android:textColor="#4F6F64"
                    android:textSize="16sp"
                    android:textStyle="bold"/>

                <TextView
                    android:id="@+id/fileSizeValue"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="2.3 MB"
                    android:textColor="#333333"
                    android:textSize="15sp"
                    android:layout_marginBottom="16dp"/>

                <!-- UPLOAD TIME -->
                <TextView
                    android:id="@+id/uploadTimeTv"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Upload Time"
                    android:textColor="#4F6F64"
                    android:textSize="16sp"
                    android:textStyle="bold"/>

                <TextView
                    android:id="@+id/uploadTimeValue"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="2025-12-09 4:30 PM"
                    android:textColor="#333333"
                    android:textSize="15sp"/>

            </LinearLayout>
        </androidx.cardview.widget.CardView>

    </LinearLayout>
</ScrollView>
