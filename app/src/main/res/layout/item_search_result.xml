<?xml version="1.0" encoding="utf-8"?>
<androidx.cardview.widget.CardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_margin="6dp"
    app:cardCornerRadius="12dp"
    app:cardElevation="2dp"
    app:cardBackgroundColor="#FFFFFF">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:padding="14dp"
        android:background="?android:attr/selectableItemBackground">

        <!-- Type Icon with Circular Background -->
        <FrameLayout
            android:layout_width="50dp"
            android:layout_height="50dp"
            android:layout_gravity="center_vertical"
            android:layout_marginEnd="14dp">

            <View
                android:layout_width="50dp"
                android:layout_height="50dp"
                android:background="@drawable/circle_white"
                android:elevation="1dp"/>

            <ImageView
                android:id="@+id/ivTypeIcon"
                android:layout_width="50dp"
                android:layout_height="50dp"
                android:contentDescription="Content type icon"
                android:scaleType="centerInside"
                android:padding="8dp" />
        </FrameLayout>

        <!-- Content Container -->
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical"
            android:gravity="center_vertical">

            <!-- Title & Type Row -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginBottom="6dp"
                android:gravity="center_vertical">

                <TextView
                    android:id="@+id/tvResultTitle"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="Result Title"
                    android:textSize="15sp"
                    android:textStyle="bold"
                    android:textColor="#333333"
                    android:maxLines="1"
                    android:ellipsize="end"/>

                <TextView
                    android:id="@+id/tvResultType"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="🎤 Recording"
                    android:textSize="11sp"
                    android:textColor="#9C27FF"
                    android:layout_marginStart="10dp"
                    android:paddingHorizontal="8dp"
                    android:paddingVertical="3dp"
                    android:background="#F3E5F5"/>
            </LinearLayout>

            <!-- Preview Text -->
            <TextView
                android:id="@+id/tvResultPreview"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Content preview goes here..."
                android:textSize="13sp"
                android:textColor="#666666"
                android:maxLines="2"
                android:ellipsize="end"
                android:layout_marginBottom="6dp"/>

            <!-- Timestamp -->
            <TextView
                android:id="@+id/tvResultTimestamp"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="22 Feb 2026 12:34:56"
                android:textSize="11sp"
                android:textColor="#AAAAAA"/>
        </LinearLayout>

    </LinearLayout>

</androidx.cardview.widget.CardView>
