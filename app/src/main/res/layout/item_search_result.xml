<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="horizontal"
    android:padding="12dp"
    android:background="?android:attr/selectableItemBackground">

    <!-- Type Icon -->
    <ImageView
        android:id="@+id/ivTypeIcon"
        android:layout_width="48dp"
        android:layout_height="48dp"
        android:layout_gravity="center_vertical"
        android:contentDescription="Content type icon"
        android:scaleType="centerInside"
        android:layout_marginEnd="12dp" />

    <!-- Content Container -->
    <LinearLayout
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_weight="1"
        android:orientation="vertical">

        <!-- Title & Type Row -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginBottom="4dp">

            <TextView
                android:id="@+id/tvResultTitle"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="Result Title"
                android:textSize="14sp"
                android:textStyle="bold"
                android:textColor="#333333"
                android:maxLines="1"
                android:ellipsize="end" />

            <TextView
                android:id="@+id/tvResultType"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="🎤 Recording"
                android:textSize="12sp"
                android:textColor="#666666"
                android:layout_marginStart="8dp" />
        </LinearLayout>

        <!-- Preview Text -->
        <TextView
            android:id="@+id/tvResultPreview"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Content preview goes here..."
            android:textSize="12sp"
            android:textColor="#777777"
            android:maxLines="2"
            android:ellipsize="end"
            android:layout_marginBottom="4dp" />

        <!-- Timestamp -->
        <TextView
            android:id="@+id/tvResultTimestamp"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="22 Feb 2026 12:34:56"
            android:textSize="11sp"
            android:textColor="#999999" />
    </LinearLayout>

    <!-- Divider -->
    <View
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:background="#EEEEEE"
        android:layout_marginTop="12dp"
        android:layout_marginStart="-12dp"
        android:layout_marginEnd="-12dp" />

</LinearLayout>
