<?xml version="1.0" encoding="utf-8"?>
<androidx.cardview.widget.CardView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginHorizontal="12dp"
    android:layout_marginVertical="6dp"
    app:cardCornerRadius="16dp"
    app:cardElevation="4dp"
    app:cardBackgroundColor="#FFFFFF">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="14dp">

        <!-- TOP ROW: Avatar + Info + Blocked Badge -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical">

            <!-- AVATAR CIRCLE -->
            <TextView
                android:id="@+id/tvAvatar"
                android:layout_width="46dp"
                android:layout_height="46dp"
                android:text="U"
                android:textColor="#FFFFFF"
                android:textSize="18sp"
                android:textStyle="bold"
                android:gravity="center"
                android:background="@drawable/circle_green"/>

            <!-- USER INFO -->
            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical"
                android:layout_marginStart="12dp">

                <TextView
                    android:id="@+id/usernameText"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Username"
                    android:textStyle="bold"
                    android:textColor="#222222"
                    android:textSize="15sp"/>

                <TextView
                    android:id="@+id/emailText"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="email@email.com"
                    android:textColor="#777777"
                    android:textSize="13sp"
                    android:layout_marginTop="2dp"/>

                <TextView
                    android:id="@+id/roleText"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="User"
                    android:textColor="#4F6F64"
                    android:textSize="12sp"
                    android:layout_marginTop="2dp"/>

            </LinearLayout>

            <!-- BLOCKED BADGE -->
            <TextView
                android:id="@+id/tvBlockedBadge"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Blocked"
                android:textColor="#FFFFFF"
                android:textSize="11sp"
                android:background="@drawable/badge_red"
                android:paddingHorizontal="8dp"
                android:paddingVertical="3dp"
                android:visibility="gone"/>

        </LinearLayout>

        <!-- AUDIO STATS ROW -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginTop="8dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="🎵"
                android:textSize="13sp"/>

            <TextView
                android:id="@+id/tvAudioCount"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="0 audios"
                android:textColor="#4F6F64"
                android:textSize="12sp"
                android:textStyle="bold"
                android:layout_marginStart="4dp"/>

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"/>

            <TextView
                android:id="@+id/tvRecordedLabel"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="recorded: 0"
                android:textColor="#888888"
                android:textSize="11sp"/>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="  |  "
                android:textColor="#CCCCCC"
                android:textSize="11sp"/>

            <TextView
                android:id="@+id/tvUploadedLabel"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="uploaded: 0"
                android:textColor="#888888"
                android:textSize="11sp"/>

        </LinearLayout>

        <!-- DIVIDER -->
        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:layout_marginVertical="10dp"
            android:background="#EEEEEE"/>

        <!-- ACTION BUTTONS ROW -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="end">

            <!-- DELETE -->
            <Button
                android:id="@+id/deleteBtn"
                style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                android:layout_width="wrap_content"
                android:layout_height="34dp"
                android:text="Delete"
                android:textColor="#E53935"
                android:textSize="12sp"
                android:paddingHorizontal="12dp"
                android:insetTop="0dp"
                android:insetBottom="0dp"
                app:strokeColor="#E53935"
                app:cornerRadius="20dp"/>

            <Space android:layout_width="8dp" android:layout_height="wrap_content"/>

            <!-- CHANGE ROLE -->
            <Button
                android:id="@+id/manageRoleBtn"
                style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                android:layout_width="wrap_content"
                android:layout_height="34dp"
                android:text="Role"
                android:textColor="#4F6F64"
                android:textSize="12sp"
                android:paddingHorizontal="12dp"
                android:insetTop="0dp"
                android:insetBottom="0dp"
                app:strokeColor="#4F6F64"
                app:cornerRadius="20dp"/>

            <Space android:layout_width="8dp" android:layout_height="wrap_content"/>

            <!-- BLOCK/UNBLOCK -->
            <Button
                android:id="@+id/blockBtn"
                android:layout_width="wrap_content"
                android:layout_height="34dp"
                android:text="Block"
                android:textColor="#FFFFFF"
                android:backgroundTint="#9E9E9E"
                android:textSize="12sp"
                android:paddingHorizontal="12dp"
                android:insetTop="0dp"
                android:insetBottom="0dp"/>

        </LinearLayout>
    </LinearLayout>
</androidx.cardview.widget.CardView>