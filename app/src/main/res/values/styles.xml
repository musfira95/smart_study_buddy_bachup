<?xml version="1.0" encoding="utf-8"?>
<resources>

    <style name="Label">
        <item name="android:textColor">#333333</item>
        <item name="android:textSize">14sp</item>
        <item name="android:layout_marginTop">12dp</item>
    </style>

    <style name="Input">
        <item name="android:layout_width">match_parent</item>
        <item name="android:layout_height">wrap_content</item>
        <item name="android:background">#FFF5FB</item>
        <item name="android:padding">12dp</item>
        <item name="android:textColor">#000000</item>
    </style>

    <style name="AppDialog" parent="Theme.AppCompat.Light.Dialog.Alert">
        <item name="colorAccent">#4F6F64</item>
        <item name="colorPrimary">#4F6F64</item>
        <item name="colorControlActivated">#4F6F64</item>
        <item name="colorControlHighlight">#4F6F64</item>
        <item name="android:textColorPrimary">#222222</item>
        <item name="android:textColorSecondary">#555555</item>
        <item name="buttonBarPositiveButtonStyle">@style/AppDialog.Button</item>
        <item name="buttonBarNegativeButtonStyle">@style/AppDialog.Button</item>
    </style>

    <style name="AppDialog.Button" parent="Widget.AppCompat.Button.ButtonBar.AlertDialog">
        <item name="android:textColor">#4F6F64</item>
        <item name="android:textStyle">bold</item>
    </style>

</resources>
